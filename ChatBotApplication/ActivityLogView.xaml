<UserControl x:Class="POEChatBotApplication.Views.ActivityLogView" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="Black">

    <UserControl.Resources>
        <!-- Red gradient for navbar -->
        <LinearGradientBrush x:Key="NavbarGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0000" Offset="0"/>
            <GradientStop Color="#990000" Offset="1"/>
        </LinearGradientBrush>

        <!-- Red button style -->
        <Style TargetType="Button" x:Key="RedButtonStyle">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#990000"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#990000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#660000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red combobox style -->
        <Style TargetType="ComboBox" x:Key="RedComboBoxStyle">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF0000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Background Video -->
        <MediaElement x:Name="BackgroundVideo"
              Source="images/vvi.mp4"
              LoadedBehavior="Play"
              UnloadedBehavior="Stop"
              Stretch="UniformToFill"
              IsMuted="True"
              MediaEnded="BackgroundVideo_MediaEnded"
              Panel.ZIndex="0" />

        <!-- Black overlay with slight blur -->
        <Rectangle Panel.ZIndex="1" Fill="#CC000000">
            <Rectangle.Effect>
                <BlurEffect Radius="4" />
            </Rectangle.Effect>
        </Rectangle>

        <!-- Main Content -->
        <Grid Panel.ZIndex="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navigation Bar -->
            <DockPanel Grid.Row="0" Height="60" Background="{StaticResource NavbarGradient}" LastChildFill="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" DockPanel.Dock="Left">
                    <TextBlock Text="📊 CyberBot Logs" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                </StackPanel>
            </DockPanel>

            <!-- Main Content with Rounded Container -->
            <Border Grid.Row="1" Margin="20" Background="Black" Padding="20" CornerRadius="10"
                    BorderBrush="#FF0000" BorderThickness="1">
                <StackPanel>
                    <!-- Filter and Clear -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,20" Background="Transparent">
                        <TextBlock Text="🔍 Filter by Category:"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="Red"
                                   Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource RedComboBoxStyle}" 
                                  Width="150" 
                                  SelectionChanged="FilterLog_SelectionChanged">
                            <ComboBoxItem Content="All" IsSelected="True" Foreground="White" Background="Black"/>
                            <ComboBoxItem Content="Task" Foreground="White" Background="Black"/>
                            <ComboBoxItem Content="Quiz" Foreground="White" Background="Black"/>
                            <ComboBoxItem Content="Chat" Foreground="White" Background="Black"/>
                        </ComboBox>
                        <Button Content="🗑️ Clear Log"
                                Style="{StaticResource RedButtonStyle}"
                                Margin="20,0,0,0"
                                Width="100"
                                Click="ClearLog_Click"/>
                    </StackPanel>

                    <!-- Rounded DataGrid -->
                    <Border CornerRadius="8" 
                            BorderThickness="1" 
                            BorderBrush="#FF0000" 
                            Background="Black" 
                            SnapsToDevicePixels="True">
                        <DataGrid ItemsSource="{Binding ActivityLog}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowBackground="#1A1A1A"
                                  AlternatingRowBackground="#2A2A2A"
                                  FontSize="14"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontFamily="Segoe UI"
                                  Foreground="Red">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="⏱️ Time" 
                                                   Width="200" 
                                                   Binding="{Binding Timestamp, StringFormat='{}{0:G}'}"/>
                                <DataGridTextColumn Header="📝 Activity" 
                                                   Width="*" 
                                                   Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="🏷️ Category" 
                                                   Width="150" 
                                                   Binding="{Binding Category}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
