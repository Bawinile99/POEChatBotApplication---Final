<UserControl x:Class="POEChatBotApplication.Views.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:POEChatBotApplication.Views"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- Red-White Cyber Terminal Button -->
        <Style TargetType="Button" x:Key="CyberTerminalButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="BorderBrush" Value="Red"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#220000"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red-White Cyber Radio Button -->
        <Style TargetType="RadioButton" x:Key="CyberHackerRadio">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="Black"/>
            <Setter Property="BorderBrush" Value="Red"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Radio Indicator -->
                                <Border Grid.Column="0" Width="16" Height="16" BorderBrush="White" 
                                        BorderThickness="1" Margin="0,0,10,0" CornerRadius="8">
                                    <Ellipse x:Name="Indicator" Fill="Transparent" Width="10" Height="10"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Fill" Value="Red"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#220000"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Black">
        <!-- Main Cyber Terminal -->
        <Border CornerRadius="5" BorderBrush="Red" BorderThickness="1" Margin="20" Background="Black" SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Terminal Header -->
                <Border Grid.Row="0" Background="Black" BorderBrush="Red" BorderThickness="0,0,0,1"
                        CornerRadius="5,5,0,0" Padding="15">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="Red" Margin="0,0,10,0"/>
                        <Ellipse Width="12" Height="12" Fill="White" Margin="0,0,10,0"/>
                        <Ellipse Width="12" Height="12" Fill="GreenYellow" Margin="0,0,15,0"/>
                        <TextBlock Text="NEURAL CHALLENGE TERMINAL" FontSize="18" FontWeight="Bold"
                                   Foreground="IndianRed" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Terminal Content -->
                <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Question Progress -->
                        <TextBlock x:Name="QuestionProgress" 
                                   Text="Question 1/15" 
                                   FontSize="12" 
                                   Foreground="White" 
                                   FontFamily="Consolas"
                                   Margin="0,0,0,10"/>

                        <!-- Question Display -->
                        <Border Background="#110000" BorderBrush="Red" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                            <TextBlock x:Name="QuestionText" Text=">_ INITIALIZING KNOWLEDGE MATRIX..." 
                                       FontSize="16" FontWeight="Bold" Foreground="White" FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Answer Options -->
                        <ItemsControl x:Name="OptionsPanel" Margin="0,0,0,25">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource CyberHackerRadio}"
                                                 Content="{Binding Text}"
                                                 GroupName="QuizOptions"
                                                 Margin="0,8"
                                                 AutomationProperties.Name="{Binding Text}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Terminal Feedback -->
                        <Border Background="#110000" BorderBrush="Red" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                            <TextBlock x:Name="FeedbackText" Text=">_ AWAITING USER INPUT..." 
                                       FontSize="14" FontStyle="Italic" Foreground="White" 
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Explanation Text (Hidden initially) -->
                        <Border x:Name="ExplanationBorder" Background="#001100" BorderBrush="Green" BorderThickness="1" 
                                Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                            <TextBlock x:Name="ExplanationText" 
                                       FontSize="14" Foreground="LightGreen" 
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Terminal Footer -->
                <Border Grid.Row="2" Background="Black" BorderBrush="Red" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,5,5" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Progress Display -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="SYSTEM INTEGRITY: " FontSize="12" Foreground="White" 
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="ScoreProgressBar" Height="10" Minimum="0" Maximum="15" Value="0"
                                         Foreground="Red" Background="#220000" Margin="5,0" Width="150"/>
                        </StackPanel>

                        <!-- Submit Button -->
                        <Button x:Name="SubmitAnswerButton" Grid.Column="1" Content="SUBMIT ANSWER" Foreground="RED"
                                Style="{StaticResource CyberTerminalButton}" Click="SubmitAnswer_Click"/>

                        <!-- Score Display -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="SCORE: " FontSize="12" Foreground="White" 
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ScoreText" Text="0/15" FontSize="14" Foreground="Red" 
                                       FontWeight="Bold" FontFamily="Consolas" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>