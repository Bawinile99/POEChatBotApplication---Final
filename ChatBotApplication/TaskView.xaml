<UserControl x:Class="POEChatBotApplication.Views.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Cyber Gradient Theme -->
        <LinearGradientBrush x:Key="CyberNavbarGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0000" Offset="0"/>
            <GradientStop Color="#990000" Offset="1"/>
        </LinearGradientBrush>

        <!-- Glowing Red Effect -->
        <Style x:Key="GlowEffect" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF0000" BlurRadius="15" Opacity="0.7" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hexagon Button -->
        <Style x:Key="HexButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Path Data="M 25,0 50,15 50,40 25,55 0,40 0,15 Z"
                                  Fill="#FF0000" Stretch="Uniform"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                </Path.RenderTransform>
                            </Path>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cyber Input Field -->
        <Style x:Key="CyberInput" TargetType="TextBox">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF0000"/>
            <Setter Property="BorderThickness" Value="0 0 0 2"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#FF0000"/>
        </Style>

        <!-- Task Card Style -->
        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#330000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF0000" BlurRadius="10" Opacity="0.3" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="Black" Padding="10">
        <Grid>
            <!-- Main Container -->
            <Border CornerRadius="15" Background="#0F0F0F" BorderBrush="#FF0000" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Circuit Pattern -->
                    <Border Grid.Row="0" Height="70" Background="{StaticResource CyberNavbarGradient}" CornerRadius="15,15,0,0">
                        <Grid>
                            <Path Data="M0,20 L800,20 M0,40 L800,40 M0,60 L800,60" 
                                  Stroke="#FF0000" StrokeThickness="1" Opacity="0.3"
                                  Stretch="Fill"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                <TextBlock Text="⚡" FontSize="24" Margin="0,0,10,0"/>
                                <TextBlock Text="CYBER TASK DECK" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Grid Grid.Row="1" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel - Task Creation -->
                        <Border Grid.Column="0" Background="#111" CornerRadius="10" Padding="15">
                            <StackPanel>
                                <TextBlock Text="CREATE NEW TASK" FontSize="18" FontWeight="Bold" Foreground="#FF0000" Margin="0,0,0,15"/>

                                <TextBlock Text="TITLE" FontSize="12" Foreground="#FF5555" Margin="0,0,0,5"/>
                                <TextBox x:Name="TaskTitleBox" Style="{StaticResource CyberInput}" Margin="0,0,0,15"/>

                                <TextBlock Text="DESCRIPTION" FontSize="12" Foreground="#FF5555" Margin="0,0,0,5"/>
                                <TextBox x:Name="TaskDescriptionBox" Style="{StaticResource CyberInput}" 
                                         Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                                <TextBlock Text="DUE DATE" FontSize="12" Foreground="#FF5555" Margin="0,0,0,5"/>
                                <DatePicker x:Name="ReminderDatePicker" Background="#111" Foreground="White" 
                                            BorderBrush="#FF0000" BorderThickness="0,0,0,2" Margin="0,0,0,20"/>

                                <Button Content="DEPLOY TASK" Click="AddTask_Click" 
                                        Style="{StaticResource HexButton}" FontSize="16" HorizontalAlignment="Center" Width="120"/>
                            </StackPanel>
                        </Border>

                        <!-- Divider -->
                        <Border Grid.Column="1" Background="#FF0000" Width="2" Opacity="0.3" Margin="0,20"/>

                        <!-- Right Panel - Task List -->
                        <Border Grid.Column="2" Background="Transparent" Padding="5">
                            <StackPanel>
                                <TextBlock Text="ACTIVE TASKS" FontSize="18" FontWeight="Bold" Foreground="#FF0000" Margin="0,0,0,15"/>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                                    <ListBox x:Name="TaskListView" ItemsSource="{Binding Tasks}" Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TaskCard}" Padding="15">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="#FFAAAA"/>
                                                            <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#AAA" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding ReminderDate, StringFormat='⌛ {0:dd MMM yyyy}'}"
                                                                       FontSize="12" Foreground="#FF5555" Margin="0,8,0,0"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="✏" Style="{StaticResource HexButton}" Width="30" Height="30" 
                                                                    Tag="{Binding}" Click="EditTask_Click" Margin="0,0,5,0"/>
                                                            <Button Content="✕" Style="{StaticResource HexButton}" Width="30" Height="30" 
                                                                    Tag="{Binding}" Click="DeleteTask_Click"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Cyber Decoration Elements -->
            <Canvas>
                <Ellipse Width="200" Height="200" Canvas.Left="-100" Canvas.Top="-100" 
                         Fill="#FF0000" Opacity="0.05"/>
                <Ellipse Width="150" Height="150" Canvas.Right="-50" Canvas.Bottom="-50" 
                         Fill="#FF0000" Opacity="0.05"/>
            </Canvas>
        </Grid>
    </Border>
</UserControl>