<Window x:Class="POEChatBotApplication.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ CyberBot Security Suite"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Height="700"
        Width="700"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Glowing Effect -->
        <DropShadowEffect x:Key="GlowEffect" 
                          Color="Red" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="0.8"/>

        <DropShadowEffect x:Key="StrongGlow" 
                          Color="Red" 
                          BlurRadius="40" 
                          ShadowDepth="0" 
                          Opacity="1.0"/>
    </Window.Resources>

    <Grid>
        <!-- Animated Background Matrix Rain Effect -->
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.5">
                <GradientStop Color="#0a0a0a" Offset="0.0"/>
                <GradientStop Color="#1a0000" Offset="0.4"/>
                <GradientStop Color="#0d0d0d" Offset="0.8"/>
                <GradientStop Color="#000000" Offset="1.0"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Matrix Rain Text (Fake falling characters) -->
        <ItemsControl Margin="0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Random Matrix characters will be added in code-behind -->
        </ItemsControl>

        <!-- Glowing Circle Rings -->
        <Ellipse Width="450" Height="450" 
                 Stroke="#FF0000" 
                 StrokeThickness="1" 
                 Opacity="0.1"
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotate1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="500" Height="500" 
                 Stroke="#FF4444" 
                 StrokeThickness="0.5" 
                 Opacity="0.15"
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotate2"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="550" Height="550" 
                 Stroke="#FF0000" 
                 StrokeThickness="0.5" 
                 Opacity="0.08"
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotate3"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Main Circular Progress -->
        <Viewbox Width="280" Height="280" 
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center">
            <Grid>
                <!-- Glowing Background Circle -->
                <Ellipse Stroke="#333333" 
                         StrokeThickness="12" 
                         Opacity="0.3"/>

                <!-- Background Circle with glow -->
                <Ellipse Stroke="#FF0000" 
                         StrokeThickness="12" 
                         Opacity="0.2">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Red" BlurRadius="30" Opacity="0.3"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Progress Arc with Glow -->
                <Path x:Name="ProgressArc"
                      Stroke="#FF0000"
                      StrokeThickness="12"
                      Fill="Transparent"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Path.Effect>
                        <DropShadowEffect Color="Red" BlurRadius="25" Opacity="0.9"/>
                    </Path.Effect>
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure x:Name="ProgressFigure"
                                        StartPoint="100,0"
                                        IsClosed="False">
                                <ArcSegment x:Name="ProgressArcSegment"
                                            Point="100,0"
                                            Size="94,94"
                                            SweepDirection="Clockwise"
                                            IsLargeArc="False"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Center Content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Animated Cyber Lock Icon -->
                    <TextBlock Grid.Row="0" 
                               Text="🔒" 
                               FontSize="60" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-20,0,0">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="LockScale"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- Title with Glow -->
                    <TextBlock Grid.Row="1" 
                               Text="CYBER-BOT" 
                               FontFamily="Consolas"
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#FF0000"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,5,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Red" BlurRadius="15" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock Grid.Row="2" 
                               Text="⚡ Security Suite v3.0" 
                               FontFamily="Consolas"
                               FontSize="11" 
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,5,0,0"/>
                </Grid>
            </Grid>
        </Viewbox>

        <!-- Loading Percentage -->
        <TextBlock x:Name="LoadingPercent" 
                   Text="0%" 
                   FontFamily="Consolas"
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#FF6666"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,230,0,0">
            <TextBlock.Effect>
                <DropShadowEffect Color="Red" BlurRadius="10" Opacity="0.5"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Bottom Content -->
        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,50" HorizontalAlignment="Center">
            <!-- Animated Loading Text -->
            <TextBlock x:Name="LoadingStatus" 
                       Text="⚡ INITIALIZING NEURAL NETWORK..." 
                       FontFamily="Consolas"
                       FontSize="13" 
                       FontWeight="Bold"
                       Foreground="#44FF44"
                       HorizontalAlignment="Center"
                       Opacity="0.9">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FF00" BlurRadius="10" Opacity="0.3"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Status Dots Animation -->
            <TextBlock Text="● ● ●" 
                       FontSize="16" 
                       Foreground="#FF0000"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       Margin="0,10,0,0">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="DotsScale"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <!-- Version Info -->
            <TextBlock Text="🔐 Secured Connection | v3.0.0" 
                       FontSize="10" 
                       Foreground="#444444"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
        </StackPanel>

        <!-- Top Right Security Badge -->
        <Border CornerRadius="3" 
                Background="#0a0a0a" 
                BorderBrush="#333333" 
                BorderThickness="1"
                Padding="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,20,20,0">
            <TextBlock Text="🔐 SECURE" 
                       FontFamily="Consolas"
                       FontSize="9" 
                       Foreground="#44FF44"
                       FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>